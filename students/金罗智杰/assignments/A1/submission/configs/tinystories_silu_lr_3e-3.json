{
  "model": {
    "vocab_size": 10000,
    "context_length": 256,
    "d_model": 512,
    "num_layers": 4,
    "num_heads": 16,
    "d_ff": 2048,
    "rope_theta": 10000.0,
    "remove_rmsnorm": false,
    "use_post_norm": false,
    "remove_rope": false,
    "ffn_type": "silu"
  },
  "training": {
    "device": "cuda",
    "seed": 42,
    "batch_size": 128,
    "eval_batch_size": 64,
    "max_steps": 10000,
    "warmup_steps": 200,
    "max_learning_rate": 0.003,
    "min_learning_rate": 0.00003,
    "betas": [0.9, 0.95],
    "eps": 1e-8,
    "weight_decay": 0.1,
    "max_grad_norm": 1.0,
    "log_interval": 10,
    "eval_interval": 100,
    "eval_batches": 20,
    "checkpoint_interval": 1000
  },
  "data": {
    "train": "data/tinystories_train.npy",
    "validation": "data/tinystories_valid.npy"
  },
  "output": {
    "log": "runs/tinystories_silu_lr_3e-3/metrics.jsonl",
    "checkpoint_dir": "runs/tinystories_silu_lr_3e-3/checkpoints"
  }
}
